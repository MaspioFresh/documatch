# =============================================================================
# DocuMatch — Template Variabili d'Ambiente
# =============================================================================
# Copiare questo file in ".env" e compilare i valori per il proprio ambiente.
# Il file ".env" NON deve mai essere committato nel repository (vedi .gitignore).
#
# SVILUPPO LOCALE: non è necessario creare il file .env.
#   L'app funziona con i valori di fallback offline (OCR mock, storage locale).
#
# PRODUZIONE AZURE: impostare le variabili nel pannello
#   "Configuration → Application settings" di Azure App Service / ACI.
# =============================================================================


# --- SICUREZZA (OBBLIGATORIO IN PRODUZIONE) ---

# Chiave segreta per la firma HMAC-SHA256 dei token di sessione.
# Generare un valore casuale sicuro, es: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_questa_chiave_prima_del_deploy_azure

# Password dell'utente 'admin' creata al primo avvio (se il DB è vuoto).
# IMPORTANTE: cambiarla subito dopo il primo login in produzione.
ADMIN_DEFAULT_PASSWORD=cambia_questa_password_prima_del_deploy_azure

# Durata della sessione in ore (default: 8)
# SESSION_EXPIRE_HOURS=8

# Origini consentite per le richieste CORS dal frontend.
# In locale: non impostare (il default "*" permette tutto).
# In produzione: inserire il dominio pubblico del frontend Azure.
# Esempio con più domini (separati da virgola):
# CORS_ALLOWED_ORIGINS=https://documatch.azurewebsites.net,https://www.documatch.it
CORS_ALLOWED_ORIGINS=*


# --- AZURE AI DOCUMENT INTELLIGENCE (OCR — opzionale) ---
# Se non impostato, l'app usa il servizio OCR Mock locale (gratuito, offline).
# Recuperare da: portale Azure → Document Intelligence → Chiavi ed Endpoint

AZURE_DOCUMENT_INTELLIGENCE_KEY=
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=


# --- AZURE BLOB STORAGE (Storage Immagini — opzionale) ---
# Se non impostato, l'app salva le immagini nella cartella locale app/static/uploads/.
# Recuperare da: portale Azure → Storage Account → Chiavi di accesso → Stringa di connessione

AZURE_STORAGE_CONNECTION_STRING=


# --- DATABASE RELAZIONALE (Produzione Cloud — opzionale) ---
# Se non impostato, l'app usa SQLite locale (documatch.db).
# In cloud, impostare la stringa per PostgreSQL o Azure SQL, es:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=


# --- AZURE OPENAI SERVICE (Generative AI — opzionale) ---
# Se non impostato, l'app usa spiegazioni locali (spaCy) e mock nel chatbot.
# Recuperare da: portale Azure → Azure OpenAI → Chiavi ed Endpoint
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-15-preview
